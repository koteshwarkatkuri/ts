import numpy as np
import pandas as pd

# Step 1: Input the quarterly sales data
data = {
    'Year': [2022, 2023, 2024],
    'Q1': [200, 210, 220],
    'Q2': [250, 260, 270],
    'Q3': [180, 190, 200],
    'Q4': [220, 230, 240]
}
df = pd.DataFrame(data)

# Step 2: Compute Link Relatives
link_relatives = []
for i in range(len(df)):
    row = []
    if i > 0:
        row.append((df.loc[i, 'Q1'] / df.loc[i - 1, 'Q4']) * 100)  # Q1 vs Previous Q4
    for j in range(1, 4):
        row.append((df.iloc[i, j] / df.iloc[i, j - 1]) * 100)  # Other quarters
    link_relatives.append(row)



Practical 8 . Calculation of variance of random component by variate difference method

---------------------------------------------------------------------------------------------------------------------------------------------------------

import numpy as np

def variate_difference_variance(data):
    """
    Calculate the variance of a random component using the variate difference method.

    Parameters:
        data (list or numpy array): A sequence of observations.

    Returns:
        float: Estimated variance.
    """
    n = len(data)
    if n < 2:
        raise ValueError("Data must contain at least two observations.")

    diff_sq = [(data[i+1] - data[i])**2 for i in range(n-1)]
    variance = (1 / (2 * (n - 1))) * sum(diff_sq)

    return variance


Practical 9 . Forecasting by exponential smoothing

-------------------------------------------------------------------------------------------------------------


import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from statsmodels.tsa.holtwinters import SimpleExpSmoothing, ExponentialSmoothing

# Generate synthetic time series data
np.random.seed(42)
date_range = pd.date_range(start="2020-01-01", periods=50, freq="M")
data = np.cumsum(np.random.randn(50)) + 100  # Random walk with drift
df = pd.DataFrame(data, index=date_range, columns=["Value"])

# Plot the data
plt.figure(figsize=(10, 5))
plt.plot(df, label="Original Data")
plt.title("Time Series Data")
plt.legend()
plt.show()

# Apply Simple Exponential Smoothing (SES)
model_ses = SimpleExpSmoothing(df["Value"]).fit(smoothing_level=0.2, optimized=False)
df["SES_Forecast"] = model_ses.fittedvalues

# Apply Double Exponential Smoothing (Holt’s Method)
model_holt = ExponentialSmoothing(df["Value"], trend="add").fit()
df["Holt_Forecast"] = model_holt.fittedvalues

# Apply Triple Exponential Smoothing (Holt-Winters Method)
model_holt_winters = ExponentialSmoothing(df["Value"], trend="add", seasonal="add", seasonal_periods=12).fit()
df["Holt_Winters_Forecast"] = model_holt_winters.fittedvalues

# Plot results
plt.figure(figsize=(12, 6))
plt.plot(df["Value"], label="Original Data", marker="o")
plt.plot(df["SES_Forecast"], label="SES Forecast", linestyle="--")
plt.plot(df["Holt_Forecast"], label="Holt Forecast", linestyle="--")
plt.plot(df["Holt_Winters_Forecast"], label="Holt-Winters Forecast", linestyle="--")
plt.title("Exponential Smoothing Forecasting")
plt.legend()
plt.show()



Practical 10 . Forecasting by short term forecasting methods
-------------------------------------------------------------------------------------------------------------


#1. Moving Average (MA)
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# Generate sample data
np.random.seed(42)
data = np.cumsum(np.random.randn(100))  # Random walk time series

# Moving average
window = 5
moving_avg = pd.Series(data).rolling(window=window).mean()

# Plot
plt.plot(data, label="Actual")
plt.plot(moving_avg, label=f"Moving Average (Window={window})", linestyle="dashed")
plt.legend()
plt.show()


#2. Exponential Smoothing

from statsmodels.tsa.holtwinters import SimpleExpSmoothing

# Fit model
ses_model = SimpleExpSmoothing(data).fit(smoothing_level=0.2, optimized=False)
forecast = ses_model.forecast(10)

# Plot
plt.plot(data, label="Actual")
plt.plot(ses_model.fittedvalues, label="SES Fitted", linestyle="dashed")
plt.plot(range(len(data), len(data) + 10), forecast, label="Forecast", linestyle="dotted")
plt.legend()
plt.show()

#3. ARIMA
from statsmodels.tsa.arima.model import ARIMA

# Fit ARIMA model
model = ARIMA(data, order=(2,1,2))
arima_fit = model.fit()

# Forecast
forecast = arima_fit.forecast(steps=10)

# Plot
plt.plot(data, label="Actual")
plt.plot(range(len(data), len(data) + 10), forecast, label="Forecast", linestyle="dotted")
plt.legend()
plt.show()
