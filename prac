plt.plot(df['Sales'], label='Original Data', marker='o') 
plt.plot(df['12-Month CMA'], label='Centered 12-Month Moving Average', color='orange') 
plt.title('Centered Moving Average Trend') 
plt.xlabel('Date') 
plt.ylabel('Sales') 
